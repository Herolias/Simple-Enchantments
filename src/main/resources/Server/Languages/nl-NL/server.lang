customUI.walkthrough.returnScroll.yes = zul
customUI.walkthrough.returnScroll.no = zul niet

# Walkthrough Descriptions
enchantment.sharpness.walkthrough = Verhoogt melee-schade met {amount}% per niveau. Van toepassing op zwaarden en bijlen.
enchantment.life_leech.walkthrough = Geneest de aanvaller voor {amount}% van de toegebrachte schade. Van toepassing op melee-wapens.
enchantment.durability.walkthrough = Vermindert de kans op duurzaamheidsverlies met {amount}% per niveau. Van toepassing op alle wapens, gereedschap en harnassen.
enchantment.sturdy.walkthrough = Voorkomt maximaal duurzaamheidsverlies bij reparatie. Van toepassing op alle wapens, gereedschap en harnassen.
enchantment.dexterity.walkthrough = Vermindert uithoudingskosten met {amount}% per niveau. Van toepassing op melee-wapens, schilden en staven.
enchantment.protection.walkthrough = Vermindert inkomende fysieke schade met {amount}% per harnasdeel per niveau. Van toepassing op harnassen.
enchantment.efficiency.walkthrough = Verhoogt mijnsnelheid met {amount}% per niveau. Van toepassing op pikhouwelen, bijlen en schoppen.\n\nVoorlopig kan deze betovering alleen verhogen hoe snel een blok breekt, niet hoe snel je pikhouweel zwaait vanwege Hytale-beperkingen.
enchantment.fortune.walkthrough = Verhoogt de kans op extra erts-/kristaldrops met {amount}% per niveau. Van toepassing op pikhouwelen. Niet combineerbaar met Perfecte Greep of Smelten.
enchantment.smelting.walkthrough = Smelt automatisch gedolven blokken. Van toepassing op pikhouwelen. Niet combineerbaar met Perfecte Greep of Fortuin.
enchantment.strength.walkthrough = Verhoogt projectielschade met {amount}% per niveau. Van toepassing op afstandswapens.
enchantment.eagles_eye.walkthrough = Verhoogt projectielschade tot {amount}% op basis van afstand per niveau. Van toepassing op afstandswapens.
enchantment.looting.walkthrough = Verhoogt maximale buitpercentages van mobs met {amount}% per niveau en verhoogt de kans op zeldzame buit. Van toepassing op melee-wapens, afstandswapens en staven.
enchantment.feather_falling.walkthrough = Vermindert valschade met {amount}% per niveau. Van toepassing op laarzen.
enchantment.waterbreathing.walkthrough = Vermindert zuurstofverbruik met {amount}% per niveau. Van toepassing op helmen.
enchantment.burn.walkthrough = Steekt het doelwit in brand, veroorzaakt {amount} schade per seconde gedurende {duration} seconden, en laat het gekookte varianten van zijn buit vallen. Van toepassing op melee- en afstandswapens. Niet combineerbaar met Bevriezen.
enchantment.freeze.walkthrough = Vertraagt het doelwit met {amount}% gedurende {duration} seconden bij een treffer. Van toepassing op melee- en afstandswapens. Niet combineerbaar met Verbranden.
enchantment.eternal_shot.walkthrough = Laat je pijlen schieten zonder ze te verbruiken. Je hebt nog steeds 1 pijl nodig in je inventaris. Van toepassing op afstandswapens.
enchantment.pick_perfect.walkthrough = Gedolven blokken laten zichzelf vallen in plaats van hun gebruikelijke buit. Van toepassing op pikhouwelen, bijlen en schoppen. Niet combineerbaar met Fortuin of Smelten.
enchantment.thrift.walkthrough = Herstelt {amount}% van het gebruikte mana per treffer per niveau. Van toepassing op manastaven.
enchantment.elemental_heart.walkthrough = Elementaire Staven verbruiken geen essentie bij het casten. Van toepassing op essentiestaven.
enchantment.knockback.walkthrough = Slaat doelen terug bij een treffer. Van toepassing op melee-wapens.
enchantment.reflection.walkthrough = Reflecteert {amount}% van geblokkeerde schade terug naar de aanvaller per niveau. Van toepassing op schilden. Niet combineerbaar met Absorptie.
enchantment.absorption.walkthrough = Geneest de blokker voor {amount}% van de geblokkeerde schade per niveau. Van toepassing op schilden. Niet combineerbaar met Reflectie.
enchantment.fast_swim.walkthrough = Verhoogt zwemsnelheid met {amount}% per niveau. Van toepassing op handschoenen.
enchantment.night_vision.walkthrough = Verbetert het zicht in donkere omgevingen zoals grotten, 's nachts en onder water. Van toepassing op helmen.\n\nDeze betovering is standaard uitgeschakeld omdat ik niet helemaal tevreden ben met de kwaliteit van het effect. Maar het is het beste van wat mogelijk is met de huidige Hytale-beperkingen.
enchantment.ranged_protection.walkthrough = Vermindert inkomende projectiel- en magieschade met {amount}% per harnasdeel per niveau. Van toepassing op harnassen.
enchantment.frenzy.walkthrough = Verhoogt de oplaadsnelheid van de kenmerkende vaardigheid met {amount}% per niveau. Van toepassing op alle wapens en staven.
enchantment.riposte.walkthrough = Dit is een samenwerkingsbetovering met de Perfect Parries mod en werkt alleen als beide mods zijn geïnstalleerd.\n\nVerhoogt tegenaanvalschade met {amount}% per niveau. Van toepassing op melee-wapens.
enchantment.coup_de_grace.walkthrough = Dit is een samenwerkingsbetovering met de Perfect Parries mod en werkt alleen als beide mods zijn geïnstalleerd.\n\nVerhoogt schade aan verdoofde vijanden met {amount}% per niveau. Van toepassing op melee-wapens.


