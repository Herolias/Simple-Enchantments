$C = "../Common.ui";

$C.@PageOverlay {}

Group {
  Anchor: (Width: 512, Height: 690);
  Background: "../Common/Enchantment UI/Scroll_Cleansing_Page.png";

  Group {
    Anchor: (Top: 15, Left: 0, Right: 0, Height: 30);
    Label #TitleLabel {
      Text: %server.customUI.cleansingScrollPage.title;
      Style: (FontSize: 22, RenderBold: true, TextColor: #7da1c0cb, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }

  Group {
    LayoutMode: Top;
    Padding: (Horizontal: 60, Top: 80, Bottom: 70);

    Group {
      LayoutMode: Left;
      Padding: (Right: 15, Bottom: 5);

      Label #ItemLabel {
        FlexWeight: 1;
        Text: %server.customUI.cleansingScrollPage.item;
        Style: (RenderBold: true, TextColor: #333333);
      }

      Label #EnchantmentLabel {
        Text: %server.customUI.cleansingScrollPage.enchantments;
        Style: (RenderBold: true, TextColor: #333333);
      }
    }

    Group #ElementList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
    }
  }
}

$C.@BackButton {}
