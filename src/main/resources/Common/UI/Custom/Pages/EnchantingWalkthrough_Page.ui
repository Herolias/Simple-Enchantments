$C = "../Common.ui";

Group {
  LayoutMode: Left;
  FlexWeight: 1;

  // Right Content Area
  Group {
    LayoutMode: Top;
    Padding: (Horizontal: 15, Vertical: 15);
    FlexWeight: 1;
    
    Group {
      Anchor: (Height: 30);
      Padding: (Bottom: 15);
      
      Label #Title {
        Style: (
          FontSize: 24,
          TextColor: #ffd700,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      }

      Label #ServerEnabledLabel {
        Style: (
          FontSize: 14,
          TextColor: #aaaaaa,
          HorizontalAlignment: End,
          VerticalAlignment: Center
        );
        Anchor: (Width: 300, Right: 0, Top: 0, Bottom: 0);
        Visible: false;
      }
    }

    Label #ModNameLabel {
      Style: (
        FontSize: 14,
        TextColor: #aaaaaa,
        HorizontalAlignment: Start
      );
      Padding: (Bottom: 15);
      Visible: false;
    }

    Label #Desc {
      Style: (
        FontSize: 16,
        TextColor: #ffffff,
        Wrap: true
      );
      Padding: (Bottom: 15);
    }
    
    TextButton #DiscordBtn {
      Style: $C.@SecondaryTextButtonStyle;
      Anchor: (Width: 200, Height: 40);
      Padding: (Horizontal: 16);
      Visible: false;
    }

    Group {
      FlexWeight: 1;
    }

    Group #NavGroup {
      LayoutMode: Left;
      Anchor: (Height: 40);

      TextButton #WalkthroughPrev {
        Style: $C.@SecondaryTextButtonStyle;
        Anchor: (Width: 120, Height: 40);
        Padding: (Horizontal: 10);
      }
      
      Group {
        FlexWeight: 1;
      }

      TextButton #WalkthroughNext {
        Style: $C.@SecondaryTextButtonStyle;
        Anchor: (Width: 120, Height: 40);
        Padding: (Horizontal: 10);
      }
    }
  }
}

