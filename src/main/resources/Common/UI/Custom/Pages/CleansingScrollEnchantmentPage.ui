$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 500, Height: 350);

  #Title {
    Group {
      $C.@Title {
        @Text = %server.customUI.cleansingEnchantmentPage.title;
      }
    }
  }

  #Content {
    Group {
      LayoutMode: Left;
      Padding: (Right: 15, Bottom: 5);

      Label {
        Text: %server.customUI.cleansingEnchantmentPage.selectHint;
        Style: (TextColor: #ffffff(0.7));
      }
    }

    Group #ElementList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
    }
  }
}

$C.@BackButton {}
