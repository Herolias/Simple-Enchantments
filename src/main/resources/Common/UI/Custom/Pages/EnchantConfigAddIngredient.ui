$C = "../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 40, Bottom: 10);

  Group {
    FlexWeight: 1;
  }

  TextButton #AddIngredientBtn {
    Style: $C.@SecondaryTextButtonStyle;
    Anchor: (Width: 190, Height: 32);
    Padding: (Horizontal: 12);
    Text: "+ Add Ingredient";
  }

  Group {
    FlexWeight: 1;
  }
}
