$C = "../Common.ui";

Group {
  Anchor: (Width: 50, Height: 50, Right: 4, Bottom: 4);

  Button #SlotButton {
    Anchor: (Full: 0);
    Padding: 1;
    Style: (
      Default: (
        Background: #151d27,
      ),
      Hovered: (
        Background: #c9a050,
      ),
      Pressed: (
        Background: #8c6f35,
      ),
      Disabled: (
        Background: #0b1016,
      ),
      Sounds: $C.@ButtonSounds,
    );

    Button #SlotInner {
      Anchor: (Full: 0);
      Style: (
        Default: (Background: #0f1720),
        Hovered: (Background: #0f1720),
        Pressed: (Background: #0f1720),
      );
      Padding: 2;
      HitTestVisible: true;

      ItemGrid #Icon {
        Anchor: (Width: 44, Height: 44, Horizontal: 0, Vertical: 0);
        SlotsPerRow: 1;
        HitTestVisible: true;
        Style: (
          SlotSize: 44,
          SlotIconSize: 40,
          SlotSpacing: 0,
          SlotBackground: "../Common/BlockSelectorSlotBackground.png"
        );
      }

      Button #ClickOverlay {
        Anchor: (Full: 0);
        HitTestVisible: false;
        Style: (
          Default: (Background: #000000(0.0)),
          Hovered: (Background: #000000(0.0)),
          Pressed: (Background: #000000(0.0)),
          Sounds: $C.@ButtonSounds
        );
      }

      Group #EmptySlot {
        Anchor: (Full: 0);
        Background: #0a1017;
        HitTestVisible: false;
      }

      Label #QuantityLabel {
        Anchor: (Width: 30, Height: 14, Right: 2, Bottom: 1);
        Style: (
          FontSize: 10,
          TextColor: #f3ead2,
          HorizontalAlignment: End,
          VerticalAlignment: End,
          RenderBold: true
        );
        Text: "";
        HitTestVisible: false;
      }
    }

    Group #SelectedOverlayPrimary {
      Anchor: (Full: 0);
      Background: #e0bd6b(0.24);
      Visible: false;
      HitTestVisible: false;
    }

    Group #SelectedOverlaySecondary {
      Anchor: (Full: 0);
      Background: #6bbde0(0.24);
      Visible: false;
      HitTestVisible: false;
    }

    Group #SelectedOverlayBoth {
      Anchor: (Full: 0);
      Background: #9ee08f(0.24);
      Visible: false;
      HitTestVisible: false;
    }

    Group #SelectedBottomLine {
      Anchor: (Height: 3, Left: 4, Right: 4, Bottom: 4);
      Background: #e0bd6b;
      Visible: false;
      HitTestVisible: false;
    }

    Label #SelectionBadge {
      Anchor: (Width: 22, Height: 16, Left: 3, Top: 3);
      Background: #e0bd6b;
      Style: (
        FontSize: 10,
        TextColor: #101418,
        HorizontalAlignment: Center,
        VerticalAlignment: Center,
        RenderBold: true
      );
      Text: "";
      Visible: false;
      HitTestVisible: false;
    }
  }
}
