$C = "../Common.ui";

// Item search sidebar - appears next to the main config window
Group {
  Background: (TexturePath: "../Common/Enchantment UI/Settings_Page.png", Border: 100);
  
  Group {
    LayoutMode: Top;
    Padding: (Full: 15);
    
    // Header with title
    Group {
      LayoutMode: Left;
      Anchor: (Height: 40, Bottom: 10);
      
      Label {
        FlexWeight: 1;
        Style: (
          FontSize: 16,
          VerticalAlignment: Center,
          RenderBold: true,
          TextColor: #b4c8c9
        );
        Text: "Select Item";
      }
      
      TextButton #CancelSearchBtn {
        Style: $C.@TertiaryTextButtonStyle;
        Anchor: (Width: 80, Height: 32);
        Padding: (Horizontal: 10);
        Text: "Cancel";
      }
    }
    
    // Search input
    $C.@TextField #ItemSearchInput {
      Anchor: (Height: 38, Bottom: 10);
      PlaceholderText: "Type to search items...";
    }
    
    // Scrollable item list
    Group #ItemSearchResults {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Right: 10);
    }
  }
}
