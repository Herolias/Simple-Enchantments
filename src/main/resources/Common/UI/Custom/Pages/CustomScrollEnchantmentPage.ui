$C = "../Common.ui";

$C.@PageOverlay {}

Group {
  Anchor: (Width: 512, Height: 690);
  Background: "../Common/Enchantment UI/Scroll_Enchanting_Page.png";

  Group {
    Anchor: (Top: 15, Left: 0, Right: 0, Height: 30);
    Label #TitleLabel {
      Text: %server.customUI.customScrollEnchantmentPage.title;
      Style: (FontSize: 22, RenderBold: true, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }

  Group {
    LayoutMode: Top;
    Padding: (Horizontal: 55, Top: 75, Bottom: 65);

    Group {
      LayoutMode: Left;
      Padding: (Right: 15, Bottom: 5);

      Label #SelectHintLabel {
        Text: %server.customUI.customScrollEnchantmentPage.selectHint;
        Style: (TextColor: #ffffff(0.7));
      }
    }

    Group #ElementList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
    }
  }
}

$C.@BackButton {}
